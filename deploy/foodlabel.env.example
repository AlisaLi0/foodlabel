# biaoqianshibie 后端配置示例。复制为 foodlabel.env 并按需修改。

# 视觉大模型（OpenAI 兼容，需支持 image_url）—— 天枢网关
LLM_BASE_URL=https://tianshu-gateway.cloud/v1
LLM_API_KEY=sk-CHANGE_ME
LLM_MODEL=OpenAI/GPT-5.5
LLM_TIMEOUT=120
# 送模型前图片长边上限（像素），控制 token 成本；0 关闭。
LLM_IMAGE_MAX_EDGE=1600
# 留空即可：GPT-5.5 等推理模型不接受自定义 temperature。仅非推理模型才设置（如 0.1）。
LLM_TEMPERATURE=

# 服务监听（loopback，由 nginx 反代）
FOODLABEL_HOST=127.0.0.1
FOODLABEL_PORT=8610

# 限制
FOODLABEL_MAX_IMAGES=4
FOODLABEL_MAX_IMAGE_BYTES=8388608
FOODLABEL_MAX_PER_HOUR=60
