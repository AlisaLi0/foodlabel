# biaoqianshibie 后端配置示例。复制为 foodlabel.env 并按需修改。

# 硅基流动（SiliconFlow）多模型：双 OCR + DeepSeek-R1 评价/比对
SF_BASE_URL=https://api.siliconflow.cn/v1
SF_API_KEY=sk-CHANGE_ME
SF_OCR_MODELS=PaddlePaddle/PaddleOCR-VL-1.5,deepseek-ai/DeepSeek-OCR
SF_REASON_MODEL=deepseek-ai/DeepSeek-R1-0528-Qwen3-8B
SF_TIMEOUT=150
# 送模型前图片长边上限（像素），控制 token 成本；0 关闭。
SF_IMAGE_MAX_EDGE=1600

# 服务监听（loopback，由 nginx 反代）
FOODLABEL_HOST=127.0.0.1
FOODLABEL_PORT=8610

# 限制
FOODLABEL_MAX_IMAGES=4
FOODLABEL_MAX_IMAGE_BYTES=8388608
FOODLABEL_MAX_PER_HOUR=60
