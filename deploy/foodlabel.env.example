# biaoqianshibie 后端配置示例。复制为 foodlabel.env 并按需修改。

# OCR 走硅基流动（SiliconFlow）识别标签文字
SF_BASE_URL=https://api.siliconflow.cn/v1
SF_API_KEY=sk-CHANGE_ME
SF_OCR_MODELS=deepseek-ai/DeepSeek-OCR
# 识读/分类/合规评价模型（默认与 OCR 同走硅基流动 Qwen/Qwen3-8B，关思考约 90s）
SF_REASON_MODEL=Qwen/Qwen3-8B
SF_REASON_BASE_URL=https://api.siliconflow.cn/v1
# 留空则回落用上面的 SF_API_KEY（同走硅基流动时无需重复填）
SF_REASON_API_KEY=
# 关闭模型思考（Qwen3 等），1=关（更快更稳），0=开
SF_REASON_NO_THINK=1
SF_TIMEOUT=180
# 送模型前图片长边上限（像素），控制 token 成本；0 关闭。
SF_IMAGE_MAX_EDGE=1600

# 服务监听（loopback，由 nginx 反代）
FOODLABEL_HOST=127.0.0.1
FOODLABEL_PORT=8610

# 限制
FOODLABEL_MAX_IMAGES=4
FOODLABEL_MAX_IMAGE_BYTES=8388608
FOODLABEL_MAX_PER_HOUR=60
