.page { padding-bottom: 48rpx; }
.intro { font-size: 24rpx; line-height: 1.7; margin: 24rpx; }

.d-title { font-size: 30rpx; font-weight: 700; line-height: 1.4; }
.d-sub { font-size: 23rpx; margin-top: 8rpx; line-height: 1.6; }

.actions { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 22rpx; }
.act-btn {
  font-size: 25rpx; padding: 14rpx 28rpx; border-radius: 40rpx;
  border: 1rpx solid var(--brand); color: var(--brand-d); background: #f5f8fd;
}
.act-btn.primary { background: var(--brand); color: #fff; border-color: var(--brand); }
.act-btn.disabled { opacity: .55; }

