.page { padding-bottom: 48rpx; }

/* 原图预览 */
.preview-wrap { margin: 24rpx 24rpx 0; }
.preview-img { width: 100%; border-radius: 16rpx; display: block; background: #f0f1f3; }
.preview-img + .preview-img { margin-top: 16rpx; }

.verdict { margin: 24rpx; padding: 32rpx; border-radius: 16rpx; }
.verdict.v-ok { background: #e7f6ec; }
.verdict.v-warn { background: #fdf6e3; }
.verdict.v-fail { background: #fdecea; }
.verdict-main { font-size: 34rpx; font-weight: 700; }
.verdict.v-ok .verdict-main { color: var(--brand); }
.verdict.v-warn .verdict-main { color: var(--warn); }
.verdict.v-fail .verdict-main { color: var(--fail); }
.verdict-sub { margin-top: 14rpx; font-size: 26rpx; color: #555; }
.verdict-sub .score { font-weight: 600; margin-right: 16rpx; }

.fingerprint {
  margin: 0 24rpx 24rpx;
  padding: 22rpx 28rpx;
  border-radius: 16rpx;
  background: #eef4ff;
  border: 1rpx solid #d6e2ff;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}
.fingerprint .fp-tag {
  font-size: 22rpx;
  color: #fff;
  background: #3b6cff;
  border-radius: 8rpx;
  padding: 4rpx 14rpx;
  margin-right: 16rpx;
}
.fingerprint .fp-name { font-size: 30rpx; font-weight: 700; color: #14213d; }
.fingerprint .fp-meta { width: 100%; margin-top: 10rpx; font-size: 24rpx; color: var(--muted); }

.card-h { font-size: 30rpx; font-weight: 700; margin-bottom: 18rpx; }
.card-h .cat { font-size: 24rpx; font-weight: 400; margin-left: 12rpx; }
.fail-h { color: var(--fail); }
.warn-h { color: var(--warn); }

.kv-row { display: flex; padding: 12rpx 0; border-bottom: 1rpx solid #f0f1f3; }
.kv-row:last-child { border-bottom: none; }
.kv-k { width: 200rpx; flex-shrink: 0; font-size: 26rpx; }
.kv-v { flex: 1; font-size: 26rpx; word-break: break-all; }

.nutri { margin-top: 24rpx; }
.nutri-h { font-weight: 600; margin-bottom: 12rpx; }
.nutri-row { display: flex; padding: 10rpx 0; border-bottom: 1rpx solid #f0f1f3; font-size: 26rpx; }
.nutri-head { color: var(--muted); font-size: 24rpx; }
.nc1 { width: 220rpx; } .nc2 { flex: 1; } .nc3 { width: 120rpx; text-align: right; }

.rule { padding: 18rpx 0; border-bottom: 1rpx solid #f0f1f3; }
.rule:last-child { border-bottom: none; }
.rule.row-fail { background: #fdf6f5; }
.rule.row-warn { background: #fdfaf0; }
.rule-top { display: flex; align-items: center; justify-content: space-between; }
.rule-item { font-size: 28rpx; font-weight: 600; }
.badges { display: flex; gap: 10rpx; }
.b { font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 20rpx; color: #fff; }
.b.pass { background: var(--brand); }
.b.miss { background: var(--miss); }
.b.fail { background: var(--fail); }
.b.warn { background: var(--warn); }
.b.na { background: #9aa0a6; }
.b.unknown { background: #9aa0a6; }
.b.pending { background: #e5e7eb; color: #6b7280; }
.rule-basis { font-size: 22rpx; margin-top: 6rpx; }
.rule-note { font-size: 24rpx; margin-top: 8rpx; color: #444; line-height: 1.6; }

.finding { padding: 16rpx 0; border-bottom: 1rpx solid #f0f1f3; }
.finding:last-child { border-bottom: none; }
.f-item { font-weight: 600; font-size: 28rpx; }
.f-detail { margin-top: 8rpx; font-size: 26rpx; line-height: 1.6; }
.f-basis { margin-top: 6rpx; font-size: 22rpx; }
.f-sug { margin-top: 6rpx; font-size: 24rpx; color: var(--brand-d); }

.disclaimer { margin: 28rpx 24rpx; font-size: 22rpx; line-height: 1.6; }
.again { margin: 0 24rpx; }
